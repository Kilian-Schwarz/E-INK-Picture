# Server URL
EINK_SERVER_URL=http://localhost:5000

# Shared auth token, sent as X-Client-Token header on all server calls
# (/settings, /preview, /api/refresh_status, /api/client_heartbeat).
# Generated by setup.sh (openssl rand -hex 32) and MUST match the
# EINK_CLIENT_TOKEN value in the server .env. Leave empty only while the
# server has no admin password set (authentication disabled).
EINK_CLIENT_TOKEN=

# Display driver: epd7in3e (6-color) or epd7in5_V2 (B/W)
EINK_DISPLAY_DRIVER=epd7in3e

# Fallback refresh interval (seconds) when server unreachable
EINK_REFRESH_INTERVAL=3600

# How often to poll server for refresh status (seconds)
EINK_POLL_INTERVAL=30

# Deployment mode: local or cloud
EINK_DEPLOYMENT_MODE=local

# Log level: DEBUG, INFO, WARNING, ERROR
EINK_LOG_LEVEL=INFO

# Debug artifact: last image sent to the display driver (PNG)
EINK_LAST_SENT_PATH=/tmp/eink_last_sent.png

# Content skip (panel care): skip the physical panel write when the preview
# PNG is byte-identical to the last successfully displayed image. Enabled by
# default; only the string "false" (case-insensitive) disables it.
EINK_CONTENT_SKIP=true

# Panel care guard: force a panel write at the latest after this many hours
# even if the content is unchanged (Waveshare recommends at least 1 refresh
# per 24h). 0 disables the guard.
EINK_MAX_SKIP_HOURS=24

# Watchdog escalation: after this many consecutive hardware failure cycles
# the client exits with a non-zero code so systemd (Restart=always,
# RestartSec=10) starts a fresh process with a freshly imported driver stack.
# 0 disables the escalation (per-cycle driver recovery still runs).
EINK_HW_FAILURE_LIMIT=3
