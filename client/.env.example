# Server URL
EINK_SERVER_URL=http://localhost:5000

# Shared auth token, sent as X-Client-Token header on all server calls
# (/settings, /preview, /api/refresh_status, /api/client_heartbeat).
# Generated by setup.sh (openssl rand -hex 32) and MUST match the
# EINK_CLIENT_TOKEN value in the server .env. Leave empty only while the
# server has no admin password set (authentication disabled).
EINK_CLIENT_TOKEN=

# Display driver: epd7in3e (6-color) or epd7in5_V2 (B/W)
EINK_DISPLAY_DRIVER=epd7in3e

# Fallback refresh interval (seconds) when server unreachable
EINK_REFRESH_INTERVAL=3600

# How often to poll server for refresh status (seconds)
EINK_POLL_INTERVAL=30

# Deployment mode: local or cloud
EINK_DEPLOYMENT_MODE=local

# Log level: DEBUG, INFO, WARNING, ERROR
EINK_LOG_LEVEL=INFO

# Debug artifact: last image sent to the display driver (PNG)
EINK_LAST_SENT_PATH=/tmp/eink_last_sent.png
