[Unit]
Description=E-Ink Picture Client
After=eink-server.service
Requires=eink-server.service

[Service]
Type=simple
User=%USER%
WorkingDirectory=%INSTALL_DIR%/client
EnvironmentFile=%INSTALL_DIR%/.env
Environment=EINK_SERVER_URL=http://localhost:5000
ExecStart=%INSTALL_DIR%/venv/bin/python3 %INSTALL_DIR%/client/client.py
Restart=on-failure
RestartSec=10
StandardOutput=append:%INSTALL_DIR%/logs/client.log
StandardError=append:%INSTALL_DIR%/logs/client.log

[Install]
WantedBy=multi-user.target
