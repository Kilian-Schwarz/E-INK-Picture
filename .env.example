# Server Configuration
PORT=5000
DATA_DIR=/app/data
SECRET_KEY=change-me-in-production

# Deployment Mode: "local" (all-in-one on Pi) or "cloud" (server on VPS)
DEPLOYMENT_MODE=local

# CORS (only relevant for cloud mode)
CORS_ALLOWED_ORIGINS=*

# Weather (optional, Open-Meteo is used by default without API key)
WEATHER_API_KEY=
WEATHER_LOCATION=

# Timezone
TZ=Europe/Berlin
