# Server Configuration
PORT=5000
DATA_DIR=/app/data

# Deployment Mode: "local" (all-in-one on Pi) or "cloud" (server on VPS)
DEPLOYMENT_MODE=local

# CORS (cloud mode only; ignored in local mode). Comma-separated list of
# explicit origins (scheme+host+port), e.g. https://eink.example.com.
# "*" is NOT allowed (credentials) and is treated as unconfigured.
CORS_ALLOWED_ORIGINS=

# --- Authentication (see CHANGELOG / README security section) ---
# As long as no admin password is set, authentication is DISABLED and the
# server behaves like before (open on the LAN, with a loud startup warning).

# Optional bootstrap of the admin password: used ONCE at startup when
# data/auth.json does not exist yet; ignored (with a warning) afterwards.
# Recommendation: set it, start the server once, then clear it here — the
# bcrypt hash is persisted in data/auth.json. Alternatively set the password
# via POST /api/auth/setup (web UI). Recovery: delete data/auth.json and
# restart (requires device access).
EINK_ADMIN_PASSWORD=

# Shared token for the headless e-ink client (header X-Client-Token on
# /settings, /preview, /api/refresh_status, /api/client_heartbeat).
# Generate manually with:  openssl rand -hex 32
# Required once a password is set, otherwise the client cannot poll.
EINK_CLIENT_TOKEN=

# Set to true only when the server runs behind a TLS-terminating proxy:
# marks the session cookie Secure (plain LAN HTTP must leave this false).
EINK_COOKIE_SECURE=false

# Home Assistant (optional). Bootstraps the read-only HA connection on first
# start when data/hass.json does not exist yet; both are ignored (with a
# warning) once a config is present. The token is stored in data/hass.json
# (mode 0600) and never logged. Configure instead via the Settings modal.
# EINK_HASS_URL: base URL of the HA instance, scheme http/https (e.g. http://10.0.0.5:8123).
EINK_HASS_URL=
# EINK_HASS_TOKEN: long-lived access token. Keep it secret; never commit a real value.
EINK_HASS_TOKEN=

# Weather (optional, Open-Meteo is used by default without API key)
WEATHER_API_KEY=
WEATHER_LOCATION=

# E-Ink Client (set when client runs on same device, e.g. http://localhost:8081)
EINK_CLIENT_URL=

# Display driver: epd7in3e (6-color Spectra 6) or epd7in5_V2 (B/W)
EINK_DISPLAY_DRIVER=epd7in3e

# GPIO pin factory for the e-ink client (gpiozero). On Raspberry Pi OS with
# kernel >= 6.6 (Bookworm/Trixie) lgpio is the ONLY working factory: the legacy
# 'native' sysfs factory is gone (OSError [Errno 22]) and RPi.GPIO edge
# detection fails. setup.sh installs python3-lgpio and pins this automatically —
# only override it on an older kernel where lgpio is unavailable (then: rpigpio).
# GPIOZERO_PIN_FACTORY=lgpio

# Server display default: waveshare_7in3_e (6-color/epd7in3e) or waveshare_7in5_v2 (B/W/epd7in5_V2).
# Only applies when settings.json has no display_type value (fresh installs).
EINK_DISPLAY_TYPE=waveshare_7in3_e

# Client polling interval (seconds). With long-polling this is only the
# reconnect backoff after a failed/timed-out status poll, not a happy-path delay.
EINK_POLL_INTERVAL=30

# Client long-poll read timeout (seconds) for GET /api/refresh_status. Must be
# strictly greater than the server hold (25s) so the server answers before the
# read times out; the default 30 leaves a safe margin.
EINK_LONGPOLL_TIMEOUT=30

# Client refresh interval fallback (seconds, when server unreachable)
EINK_REFRESH_INTERVAL=3600

# Debug artifact: last image sent to the display driver (PNG)
EINK_LAST_SENT_PATH=/tmp/eink_last_sent.png

# Client content skip (panel care): skip the physical panel write when the
# preview PNG is byte-identical to the last successfully displayed image.
# Enabled by default; only the string "false" (case-insensitive) disables it.
EINK_CONTENT_SKIP=true

# Client panel care guard: force a panel write at the latest after this many
# hours even if the content is unchanged (Waveshare recommends at least
# 1 refresh per 24h). 0 disables the guard.
EINK_MAX_SKIP_HOURS=24

# Client watchdog escalation: after this many consecutive hardware failure
# cycles the client exits with a non-zero code so systemd (Restart=always,
# RestartSec=10) starts a fresh process with a freshly imported driver stack.
# 0 disables the escalation (per-cycle driver recovery still runs).
EINK_HW_FAILURE_LIMIT=3

# Max. concurrent preview renders (int >= 1). Default 1: additional requests
# queue and abort with 503 if the client disconnects. Keeps render buffers
# from stacking up on 512-MB-class Pis.
EINK_MAX_CONCURRENT_RENDERS=

# Go runtime soft memory limit for the server. Positive integer with optional
# MiB suffix (e.g. 64MiB; bare number = bytes), "off" or "0" disables it.
# Default 64MiB. Precedence: EINK_GOMEMLIMIT > native GOMEMLIMIT env > default.
# Too low shows up as high CPU/slow renders (GC thrash), never as a crash.
EINK_GOMEMLIMIT=

# Timezone (local wall clock; also anchors the sleep window settings
# sleep_start/sleep_end evaluated by the server)
TZ=Europe/Berlin
